# SHOPLINE migration environment — copy to .env and fill in real values.
# .env is gitignored. NEVER commit real secrets.

# --- Store identity ---
SL_STORE="xxxxxx.myshopline.com"          # the *.myshopline.com admin/dev domain used by the CLI
SL_PRIMARY_DOMAIN="yourbrand.myshopline.com" # public primary domain (may differ from SL_STORE; redirects)
STOREFRONT_PASSWORD=""                      # storefront "password protection" gate value (if store is not public)

# --- Theme target ---
SL_THEME_ID=""                             # target Bottle theme id (get from: sl theme list)
SL_THEME_NAME="Bottle1"                     # human label for the target theme

# --- Admin REST API (page records, content) ---
SL_TOKEN=""                                # Admin OpenAPI access token (Staff Settings > API Auth > Generate)
SL_API_VERSION="v20260901"                 # Admin API version, e.g. v20260901 / v20260301

# --- Source control ---
GH_REPO="github.com/<owner>/<repo>"        # repo holding the theme + these docs

# --- Local validation browser (isolated Chrome for CDP) ---
CDP_PORT="9333"
CDP_PROFILE="/tmp/sl-validate-profile"
